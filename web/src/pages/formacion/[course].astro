---
import Base from '../../layouts/Base.astro';
import CourseScreen from '../../components/screens/CourseScreen.jsx';
import { DATA } from '../../lib/data.js';

// Una página estática por curso: /formacion/<id>/
export function getStaticPaths() {
  return DATA.courses.map((course) => ({
    params: { course: course.id },
    props: { course },
  }));
}

const { course } = Astro.props;
const path = `/formacion/${course.id}/`;
const title = `${course.title} — GEPCO Formación`;
const description = `${course.title}.${course.norm ? ' ' + course.norm + '.' : ''} Formación teórico-práctica con certificación oficial e instructores en activo. Reserva tu plaza o solicita propuesta para tu empresa.`;

// Schema.org Course (básico; ampliar con precio/fechas reales cuando existan).
const jsonld = {
  '@context': 'https://schema.org',
  '@type': 'Course',
  name: course.title,
  description,
  provider: {
    '@type': 'Organization',
    name: 'GEPCO Formación',
    url: 'https://gepcoformacion.es/',
  },
};
---
<Base title={title} description={description} path={path} image={course.img} jsonld={jsonld}>
  <CourseScreen courseId={course.id} client:load />
</Base>
