---
// [PENDIENTE: traducción CA] — estructura lista, contenido en catalán por traducir.
const BASE = 'https://gepcoformacion.es';
---
<!doctype html>
<html lang="ca">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>GEPCO Formació — Escola d'Emergències i PRL</title>
    <meta name="description" content="Versió en català pendent de traducció." />
    <link rel="canonical" href={BASE + '/ca/'} />
    <link rel="alternate" hreflang="es" href={BASE + '/'} />
    <link rel="alternate" hreflang="ca" href={BASE + '/ca/'} />
    <link rel="alternate" hreflang="x-default" href={BASE + '/'} />
    <link rel="stylesheet" href="/ds/tokens/fonts.css" />
    <link rel="stylesheet" href="/ds/styles.css" />
    <link rel="stylesheet" href="/global.css" />
  </head>
  <body style="display:flex;min-height:100vh;align-items:center;justify-content:center;padding:2rem;text-align:center">
    <div>
      <h1 style="font-family:var(--font-display);font-weight:800;letter-spacing:var(--tracking-display);color:var(--text-strong)">GEPCO Formació<span style="color:var(--color-brand)">.</span></h1>
      <p style="color:var(--text-body)">Versió en català — <strong>[PENDIENT: traducció]</strong>. L'estructura /ca/ i els hreflang ja estan preparats.</p>
      <p><a href="/" style="color:var(--color-brand)">Versión en español →</a></p>
    </div>
  </body>
</html>
